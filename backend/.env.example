# Required: OpenAI API key for expense classification
OPENAI_API_KEY=sk-...

# Cheapest OpenAI model (default). Override if you want better accuracy.
OPENAI_MODEL=gpt-5-nano

# Secret for signing login tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me

# Optional: 64-char hex master encryption key. If omitted, one is generated
# and stored in DATA_DIR/master.key on first boot (fine when DATA_DIR persists).
# ENCRYPTION_KEY=

# Where SQLite DB + WhatsApp sessions live. On Railway, mount a volume here.
DATA_DIR=./data

PORT=3001

# Set false to run the API without the WhatsApp bot (local testing)
WHATSAPP_ENABLED=true
